{
  "name": "spartan-react",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx,js,jsx --report-unused-disable-directives --max-warnings 2",
    "preview": "vite preview",
    "lint:staged": "lint-staged",
    "typecheck": "tsc --noEmit",
    "pre-commit": "yarn lint:staged",
    "pre-push": "yarn lint && yarn typecheck",
    "postinstall": "npx husky install",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "test": "jest"
  },
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@mui/icons-material": "^5.15.17",
    "@mui/lab": "^5.0.0-alpha.172",
    "@mui/material": "^5.16.1",
    "@tanstack/react-query": "^5.51.1",
    "apexcharts": "^3.50.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^6.24.1",
    "yup": "^1.4.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.2.3",
    "@storybook/addon-interactions": "^8.2.3",
    "@storybook/addon-links": "^8.2.3",
    "@storybook/addon-onboarding": "^8.2.3",
    "@storybook/blocks": "^8.2.3",
    "@storybook/react": "^8.2.3",
    "@storybook/react-vite": "^8.2.3",
    "@storybook/test": "^8.2.3",
    "@testing-library/dom": "^10.3.2",
    "@testing-library/react": "^16.0.0",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.10",
    "@types/numeral": "^2.0.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^8.10.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-react": "^7.34.4",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.8",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-storybook": "^0.8.0",
    "eslint-plugin-unused-imports": "^3.2.0",
    "husky": "^9.0.11",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.3",
    "storybook": "^8.2.3",
    "ts-jest": "^29.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3",
    "vite": "^5.3.3",
    "vite-tsconfig-paths": "^4.3.2"
  },
  "packageManager": "yarn@4.1.0"
