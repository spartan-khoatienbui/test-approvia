{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "~common": ["src/common"],
      "~common/*": ["src/common/*"],
      "~shared/*": ["src/shared/*"],
      "~shared": ["src/shared"],
      "~utils/*": ["src/utils/*"],
      "~utils": ["src/utils"],
      "~configs": ["src/configs"],
      "~configs/*": ["src/configs/*"],
      "~modules/*": ["src/modules/*"],
      "~modules": ["src/modules"],
      "~routers/*": ["src/routers/*"],
      "~routers": ["src/routers"],
      "~assets/*": ["src/assets/*"],
      "~assets": ["src/assets"]
    }
  }
}
